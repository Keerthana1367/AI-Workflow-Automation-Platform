# Example Environment Configuration

# Required for AI Nodes (Backend)
GROQ_API_KEY=your_groq_api_key_here

# PostgreSQL Database Connection String (Render provides this automatically)
# Leave empty or omit to default to local SQLite (platform.db)
DATABASE_URL=postgres://user:password@hostname:5432/dbname

# API URL for Frontend to connect to Backend
# Render internal routing: http://ai-workflow-backend:10000/api
# Or public URL: https://ai-workflow-backend.onrender.com/api
# Local default: http://localhost:8000/api
API_URL=http://localhost:8000/api
